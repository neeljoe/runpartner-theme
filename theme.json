{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1280px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "base",
					"name": "Base",
					"color": "#04100a"
				},
				{
					"slug": "surface",
					"name": "Surface",
					"color": "#0a1f14"
				},
				{
					"slug": "primary",
					"name": "Primary",
					"color": "#70e000"
				},
				{
					"slug": "accent",
					"name": "Accent",
					"color": "#f0c808"
				},
				{
					"slug": "contrast",
					"name": "Contrast",
					"color": "#ffffff"
				},
				{
					"slug": "muted",
					"name": "Muted",
					"color": "#a8b5b0"
				},
				{
					"slug": "subtle",
					"name": "Subtle",
					"color": "#6b7a75"
				},
				{
					"slug": "grey-100",
					"name": "Grey 100",
					"color": "#f5f7f6"
				},
				{
					"slug": "grey-200",
					"name": "Grey 200",
					"color": "#d9e2df"
				},
				{
					"slug": "grey-300",
					"name": "Grey 300",
					"color": "#a8b5b0"
				},
				{
					"slug": "grey-400",
					"name": "Grey 400",
					"color": "#6b7a75"
				},
				{
					"slug": "grey-500",
					"name": "Grey 500",
					"color": "#3d4a45"
				},
				{
					"slug": "grey-600",
					"name": "Grey 600",
					"color": "#1f2b25"
				},
				{
					"slug": "grey-700",
					"name": "Grey 700",
					"color": "#0f1814"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"customFontSize": true,
			"fontFamilies": [
				{
					"slug": "heading",
					"name": "Satoshi",
					"fontFamily": "\"Satoshi\", sans-serif",
					"fontFace": [
						{
							"fontFamily": "Satoshi",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "300 900",
							"src": [
								"file:./assets/fonts/Satoshi/Satoshi-Variable.woff2"
							]
						}
					]
				},
				{
					"slug": "body",
					"name": "Manrope",
					"fontFamily": "\"Manrope\", sans-serif",
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "200 800",
							"src": [
								"file:./assets/fonts/manrope/Manrope-VariableFont_wght.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"name": "Small",
					"size": "0.875rem",
					"lineHeight": "1.5"
				},
				{
					"slug": "sm",
					"name": "Body",
					"size": "1rem",
					"lineHeight": "1.6"
				},
				{
					"slug": "md",
					"name": "Large",
					"size": "1.25rem",
					"lineHeight": "1.5"
				},
				{
					"slug": "lg",
					"name": "H3",
					"size": "1.75rem",
					"lineHeight": "1.3"
				},
				{
					"slug": "xl",
					"name": "H2",
					"size": "2.25rem",
					"lineHeight": "1.2"
				},
				{
					"slug": "2xl",
					"name": "H1",
					"size": "clamp(2.5rem, 4vw, 3.5rem)",
					"lineHeight": "1.1"
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": ["px", "em", "rem", "%", "vw", "vh"],
			"spacingSizes": [
				{
					"slug": "10",
					"name": "XS",
					"size": "0.5rem"
				},
				{
					"slug": "20",
					"name": "SM",
					"size": "1rem"
				},
				{
					"slug": "30",
					"name": "M",
					"size": "1.5rem"
				},
				{
					"slug": "40",
					"name": "L",
					"size": "2rem"
				},
				{
					"slug": "50",
					"name": "XL",
					"size": "3rem"
				},
				{
					"slug": "60",
					"name": "2XL",
					"size": "5rem"
				}
			]
		},
		"border": {
			"defaultBorderRadius": "0",
			"radius": true,
			"width": true,
			"style": true,
			"color": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"slug": "sm",
					"name": "Small",
					"value": "0 1px 2px rgba(0, 0, 0, 0.3)"
				},
				{
					"slug": "md",
					"name": "Medium",
					"value": "0 4px 8px rgba(0, 0, 0, 0.4)"
				},
				{
					"slug": "lg",
					"name": "Large",
					"value": "0 8px 16px rgba(0, 0, 0, 0.5)"
				},
				{
					"slug": "glow-primary",
					"name": "Primary Glow",
					"value": "0 0 20px rgba(112, 224, 0, 0.4)"
				},
				{
					"slug": "glow-accent",
					"name": "Accent Glow",
					"value": "0 0 20px rgba(240, 200, 8, 0.4)"
				}
			]
		},
		"position": {
			"fixed": true,
			"sticky": true
		},
		"dimensions": {
			"minHeight": true
		},
		"css": true
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|body",
			"fontSize": "var:preset|font-size|sm",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"top": "var:preset|spacing|40",
				"bottom": "var:preset|spacing|40",
				"left": "var:preset|spacing|20",
				"right": "var:preset|spacing|20"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "700",
					"letterSpacing": "-0.02em",
					"lineHeight": "1.2"
				},
				"color": {
					"text": "var:preset|color|contrast"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|2xl"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|xl"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|lg"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|md",
					"fontWeight": "600"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|sm",
					"fontWeight": "600"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|xs",
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|primary"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|accent"
					}
				},
				":focus": {
					"color": {
						"text": "var:preset|color|accent"
					},
					"outline": {
						"width": "2px",
						"style": "solid",
						"color": "var:preset|color|accent"
					}
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|base"
				},
				"border": {
					"radius": "4px"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|10",
						"bottom": "var:preset|spacing|10",
						"left": "var:preset|spacing|20",
						"right": "var:preset|spacing|20"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|sm",
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|accent",
						"text": "var:preset|color|base"
					},
					"transform": "translateY(-2px)",
					"shadow": "var:preset|shadow|md"
				},
				":focus": {
					"outline": {
						"width": "2px",
						"style": "solid",
						"color": "var:preset|color|contrast"
					},
					"outlineOffset": "2px"
				},
				"variations": {
					"outline": {
						"color": {
							"background": "transparent",
							"text": "var:preset|color|primary"
						},
						"border": {
							"width": "2px",
							"style": "solid",
							"color": "var:preset|color|primary"
						},
						":hover": {
							"color": {
								"background": "var:preset|color|primary",
								"text": "var:preset|color|base"
							}
						}
					}
				}
			},
			"caption": {
				"typography": {
					"fontSize": "var:preset|font-size|xs",
					"fontStyle": "italic"
				},
				"color": {
					"text": "var:preset|color|muted"
				}
			},
			"cite": {
				"typography": {
					"fontSize": "var:preset|font-size|xs",
					"fontStyle": "italic"
				},
				"color": {
					"text": "var:preset|color|muted"
				}
			}
		},
		"blocks": {
			"core/separator": {
				"color": {
					"text": "var:preset|color|grey-500"
				},
				"border": {
					"width": "1px"
				}
			},
			"core/site-title": {
				"typography": {
					"fontWeight": "700",
					"letterSpacing": "-.5px",
					"fontSize": "var:preset|font-size|xl",
					"fontFamily": "var:preset|font-family|heading"
				}
			},
			"core/quote": {
				"border": {
					"color": "var:preset|color|primary",
					"width": "0 0 0 4px",
					"style": "solid"
				},
				"spacing": {
					"padding": {
						"left": "var:preset|spacing|20"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|md",
					"fontStyle": "italic"
				}
			},
			"core/code": {
				"color": {
					"background": "var:preset|color|grey-700",
					"text": "var:preset|color|grey-100"
				},
				"border": {
					"radius": "4px"
				},
				"typography": {
					"fontSize": "var:preset|font-size|xs",
					"fontFamily": "monospace"
				}
			},
			"core/pullquote": {
				"border": {
					"color": "var:preset|color|primary",
					"width": "2px 0",
					"style": "solid"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|30",
						"bottom": "var:preset|spacing|30"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|lg",
					"lineHeight": "1.4"
				}
			}
		},
		"variations": {
			"surface": {
				"color": {
					"background": "var:preset|color|surface",
					"text": "var:preset|color|contrast"
				}
			},
			"primary-band": {
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|base"
				}
			},
			"accent-band": {
				"color": {
					"background": "var:preset|color|accent",
					"text": "var:preset|color|base"
				}
			}
		}
	}
}
